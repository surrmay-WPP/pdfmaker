{
  "name": "pdfmaker",
  "private": true,
  "version": "0.0.0",
  "description": "PDF Pipeline Studio",
  "author": "Your Name",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.cjs",
    "start": "node dist/server/index.cjs",
    "start:server": "node server/index.cjs",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "node scripts/build-server.cjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "jsdom": "^27.2.0",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^24.31.0",
    "wait-on": "^9.0.4"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vite": "^7.3.1"
  },
  "pkg": {
  "assets": [
    "node_modules/**/*",
    "dist/**/*"
    ]
  }
}
